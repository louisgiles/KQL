// Sign-In Baseline
// Establishes baseline behaviour.
// Typical sign-in times, locations, device types, client applications. Success/failure ratios.
// Note: All times are UTC
// Tables: SigninLogs, AADSignInLogs
let LookbackWindow = 30d;
let TargetUsers = dynamic([]); // Populate with specific UPNs to scope, or leave empty for all users
let SigninData = union withsource=SourceTable SigninLogs, AADSignInLogs
    | where TimeGenerated >= ago(LookbackWindow)
    | where array_length(TargetUsers) == 0 or UserPrincipalName in (TargetUsers)
    | extend
        HourOfDay = hourofday(TimeGenerated),
        DayOfWeek = dayofweek(TimeGenerated) / 1h / 24,
        SigninSuccess = iff(ResultType == 0, 1, 0),
        SigninFailure = iff(ResultType != 0, 1, 0);
// ---- Per-User Baseline Summary ----
SigninData
| summarize
    TotalSignins = count(),
    SuccessCount = sum(SigninSuccess),
    FailureCount = sum(SigninFailure),
    FailureRatio = round(100.0 * sum(SigninFailure) / count(), 2),
    DistinctIPs = dcount(IPAddress),
    DistinctLocations = dcount(Location),
    DistinctDevices = dcount(DeviceDetail.displayName),
    DistinctClientApps = dcount(ClientAppUsed),
    DistinctUserAgents = dcount(UserAgent),
    TypicalLocations = make_set(Location, 10),
    TypicalClientApps = make_set(ClientAppUsed, 10),
    TypicalDeviceNames = make_set(DeviceDetail.displayName, 10),
    EarliestSignin = min(TimeGenerated),
    LatestSignin = max(TimeGenerated),
    // Hour-of-day distribution
    MorningSignins_6to12 = countif(HourOfDay >= 6 and HourOfDay < 12),
    AfternoonSignins_12to18 = countif(HourOfDay >= 12 and HourOfDay < 18),
    EveningSignins_18to24 = countif(HourOfDay >= 18 and HourOfDay < 24),
    NightSignins_0to6 = countif(HourOfDay >= 0 and HourOfDay < 6),
    // Weekend vs weekday
    WeekdaySignins = countif(DayOfWeek >= 0 and DayOfWeek < 5),
    WeekendSignins = countif(DayOfWeek >= 5)
    by UserPrincipalName
| extend
    PctNightSignins = round(100.0 * NightSignins_0to6 / TotalSignins, 2),
    PctWeekendSignins = round(100.0 * WeekendSignins / TotalSignins, 2)
| project
    UserPrincipalName,
    TotalSignins,
    SuccessCount,
    FailureCount,
    FailureRatio,
    DistinctIPs,
    DistinctLocations,
    TypicalLocations,
    DistinctDevices,
    TypicalDeviceNames,
    DistinctClientApps,
    TypicalClientApps,
    MorningSignins_6to12,
    AfternoonSignins_12to18,
    EveningSignins_18to24,
    NightSignins_0to6,
    PctNightSignins,
    WeekdaySignins,
    WeekendSignins,
    PctWeekendSignins,
    EarliestSignin,
    LatestSignin
| order by TotalSignins desc
