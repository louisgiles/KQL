// Token Replay / Session Anomaly Detection
// Identifies sessions where the authentication token is used from a different
// IP address, device, or user agent than where it was originally issued.
// Catches AiTM (Adversary-in-the-Middle) post-phishing token theft.
// Tables: SigninLogs, AADSignInLogs
let LookbackWindow = 24h;
let AllSignins = union withsource=SourceTable SigninLogs, AADSignInLogs
    | where TimeGenerated >= ago(LookbackWindow)
    | where ResultType == 0
    | extend
        DeviceName = tostring(DeviceDetail.displayName),
        DeviceOS = tostring(DeviceDetail.operatingSystem),
        BrowserUsed = tostring(DeviceDetail.browser),
        TrustType = tostring(DeviceDetail.trustType),
        IsInteractive = tostring(IsInteractive);
// ============================================================
// DETECTION 1: Same CorrelationId Used from Different IPs
// Token issued in one session, replayed from another IP
// ============================================================
let TokenReplayByCorrelation = AllSignins
    | summarize
        DistinctIPs = dcount(IPAddress),
        IPs = make_set(IPAddress, 10),
        DistinctLocations = dcount(Location),
        Locations = make_set(Location, 10),
        DistinctUserAgents = dcount(UserAgent),
        UserAgents = make_set(UserAgent, 5),
        TimeStart = min(TimeGenerated),
        TimeEnd = max(TimeGenerated),
        SigninCount = count()
        by CorrelationId, UserPrincipalName
    | where DistinctIPs > 1
    | extend
        DetectionType = "Token Replay - Correlation ID Reuse",
        TimeDeltaMinutes = datetime_diff('minute', TimeEnd, TimeStart)
    | project
        DetectionType,
        UserPrincipalName,
        CorrelationId,
        DistinctIPs,
        IPs,
        Locations,
        DistinctUserAgents,
        UserAgents,
        TimeDeltaMinutes,
        SigninCount,
        TimeStart,
        TimeEnd;
// ============================================================
// DETECTION 2: Impossible Travel — Same User, Different Geos, Short Window
// ============================================================
let ImpossibleTravelMinutes = 30;
let UserSigninPairs = AllSignins
    | project TimeGenerated, UserPrincipalName, IPAddress, Location, UserAgent, DeviceName, DeviceOS
    | order by UserPrincipalName asc, TimeGenerated asc;
let ImpossibleTravel = UserSigninPairs
    | serialize
    | extend
        NextTime = next(TimeGenerated),
        NextIP = next(IPAddress),
        NextLocation = next(Location),
        NextUserAgent = next(UserAgent),
        NextUser = next(UserPrincipalName)
    | where UserPrincipalName == NextUser
    | where Location != NextLocation
    | where IPAddress != NextIP
    | extend TimeDeltaMinutes = datetime_diff('minute', NextTime, TimeGenerated)
    | where TimeDeltaMinutes <= ImpossibleTravelMinutes and TimeDeltaMinutes >= 0
    | extend DetectionType = "Impossible Travel"
    | project
        DetectionType,
        UserPrincipalName,
        FirstSigninTime = TimeGenerated,
        FirstIP = IPAddress,
        FirstLocation = Location,
        FirstUserAgent = UserAgent,
        SecondSigninTime = NextTime,
        SecondIP = NextIP,
        SecondLocation = NextLocation,
        SecondUserAgent = NextUserAgent,
        TimeDeltaMinutes;
// ============================================================
// DETECTION 3: User Agent / Device Shift Within Same Session Window
// Same user, rapid device or UA change suggesting token export
// ============================================================
let SessionWindowMinutes = 10;
let DeviceShift = AllSignins
    | summarize
        DistinctUserAgents = dcount(UserAgent),
        UserAgents = make_set(UserAgent, 10),
        DistinctDevices = dcount(DeviceName),
        Devices = make_set(DeviceName, 10),
        DistinctOSes = dcount(DeviceOS),
        OSes = make_set(DeviceOS, 5),
        DistinctIPs = dcount(IPAddress),
        IPs = make_set(IPAddress, 10),
        SigninCount = count(),
        TimeStart = min(TimeGenerated),
        TimeEnd = max(TimeGenerated)
        by UserPrincipalName, bin(TimeGenerated, 10m)
    | where DistinctUserAgents > 1 or DistinctDevices > 1
    | where DistinctIPs > 1  // Different IP adds confidence this is token theft not just browser switching
    | extend
        DetectionType = "Device/UA Shift Within Session Window",
        TimeDeltaMinutes = datetime_diff('minute', TimeEnd, TimeStart)
    | project
        DetectionType,
        UserPrincipalName,
        DistinctUserAgents,
        UserAgents,
        DistinctDevices,
        Devices,
        DistinctIPs,
        IPs,
        SigninCount,
        TimeStart,
        TimeEnd;
// ============================================================
// DETECTION 4: Known AiTM Indicators
// Sign-ins flagged with specific risk events or from known proxy infra
// ============================================================
let AiTMIndicators = AllSignins
    | where RiskEventTypes has_any (
        "anomalousToken", "tokenIssuerAnomaly",
        "unfamiliarFeatures", "impossibleTravel",
        "mcasSuspiciousInboxManipulationRules"
    )
    or RiskLevelDuringSignIn in ("high", "medium")
    | extend DetectionType = "AiTM Risk Indicator"
    | project
        DetectionType,
        UserPrincipalName,
        TimeGenerated,
        IPAddress,
        Location,
        RiskEventTypes,
        RiskLevelDuringSignIn,
        RiskLevelAggregated,
        UserAgent,
        ClientAppUsed,
        DeviceName,
        DeviceOS;
// ============================================================
// COMBINED OUTPUT
// ============================================================
TokenReplayByCorrelation
| project DetectionType, UserPrincipalName, TimeStart, Details=pack_all()
| union (
    ImpossibleTravel
    | project DetectionType, UserPrincipalName, TimeStart=FirstSigninTime, Details=pack_all()
)
| union (
    DeviceShift
    | project DetectionType, UserPrincipalName, TimeStart, Details=pack_all()
)
| union (
    AiTMIndicators
    | project DetectionType, UserPrincipalName, TimeStart=TimeGenerated, Details=pack_all()
)
| order by TimeStart desc
